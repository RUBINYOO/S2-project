@page
@using Logic
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<head>
    <h1 class="text-center">WELKOM</h1>
</head>

<div class="input-group">
    <input type="text"
           name="search"
           class="form-control"
           placeholder="Zoek een festival..."/>
    <button class="btn btn-primary">
        Zoeken
    </button>
</div>

<div class="container my-4">
    @foreach (var item in Model.festivals)
    {
        <div class="row bg-light p-3 mb-3 align-items-center border rounded-1">
            <a asp-page="/FestivalDetails"
                   asp-route-id="@item.Id"
                   class="d-flex col-md-10 text-decoration-none text-dark">
                <div class="col-md-3 fw-bold">
                    Datum<br>
                    <span class="fw-normal">@item.Date</span>
                </div>
                <div class="col-md-7">
                    <div><strong>Naam: </strong> @item.Name</div>
                    <div><strong>Tijd: </strong> @item.StartingTime - @item.EndingTime</div>
                    <div><strong>Locatie: </strong>@item.Location</div>
                </div>
            </a>
            <div class="col-md-2 text-end">
                <button class="btn btn-outline-danger" type="button">
                    <i class="bi bi-heart"></i>
                </button>
            </div>
        </div>
    }
</div>

<!-- Bootstrap Icons -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
